<Window x:Class="PetShelter.TableWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PetShelter"
        mc:Ignorable="d"
        Title="PetShelter" Height="450" Width="800" Background="#FFF27BCF">


    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="70" />
            <RowDefinition Height="*" />
            <RowDefinition Height="70" />
        </Grid.RowDefinitions>

        <!-- СИНЯЯ ШАПКА ОКНА -->
        <Border Grid.Row="0" Background="#1F4E9E" CornerRadius="10" BorderThickness="3" BorderBrush="#FF9F00" Margin="0,0,0,10">
            <TextBlock Text="FOUND FRIENDS / РЕЗУЛЬТАТЫ ПОИСКА" Foreground="White" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold"/>
        </Border>

        <Border Grid.Row="1" Background="#FF9F00" CornerRadius="10" Padding="12">


            <DataGrid x:Name="dgPets" 
                     
                      AutoGenerateColumns="False"
                      IsReadOnly="True" 
                      Background="White"
                      BorderThickness="0"
                      RowHeight="32" 
                      FontSize="14"
                      FontFamily="Arial"
                      GridLinesVisibility="Horizontal"
                      HorizontalGridLinesBrush="#E0E0E0"
                      HeadersVisibility="Column">

                <!--  заголовки -->
                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#1F4E9E" />
                        <Setter Property="Foreground" Value="White" />
                        <Setter Property="FontWeight" Value="Bold" />
                        <Setter Property="FontSize" Value="14" />
                        <Setter Property="Padding" Value="10,6,10,6" />
                        <Setter Property="HorizontalContentAlignment" Value="Center" />
                    </Style>
                </DataGrid.ColumnHeaderStyle>

                <!-- колонки в ручную сбегали -->

                <DataGrid.Columns>
                    <!-- тип живот -->
                    <DataGridTextColumn Header="Вид питомца" Binding="{Binding TypeName}" Width="120" />


                    <DataGridTextColumn Header="Кличка питомца" Binding="{Binding Name}" Width="150" />
                    <DataGridTextColumn Header="Возраст(лет)" Binding="{Binding Age}" Width="110" />
                    <DataGridTextColumn Header="Вес(кг)" Binding="{Binding Weight}" Width="110" />
                    <DataGridTextColumn Header="Рост(см)" Binding="{Binding Height}" Width="100" />
                    <DataGridCheckBoxColumn Header="Клаустрофобия" Binding="{Binding IsClaustrophobic}" Width="*" />
                </DataGrid.Columns>


            </DataGrid>
        </Border>

        <!-- УПРАВЛЯЮЩИЕ КНОПКИ ( добавление/удаление) -->
        <Grid Grid.Row="2" Margin="0,10,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Button x:Name="btnAddPet" Grid.Column="0" Content="➕ ADOPT NEW PET" Click="BtnAddPet_Click" Height="45" Margin="0,0,10,0" Background="#FF9F00" Foreground="White" FontSize="16" FontWeight="Bold" BorderThickness="3" BorderBrush="#1F4E9E" Cursor="Hand">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="10"/>
                    </Style>
                </Button.Resources>
            </Button>

            <Button x:Name="btnRemovePet" Grid.Column="1" Content="– TAKE ME HOME" Click="BtnRemovePet_Click" Height="45" Margin="10,0,0,0" Background="#1F4E9E" Foreground="White" FontSize="16" FontWeight="Bold" BorderThickness="3" BorderBrush="#FF9F00" Cursor="Hand">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="10"/>
                    </Style>
                </Button.Resources>
            </Button>
        </Grid>
    </Grid>
</Window>